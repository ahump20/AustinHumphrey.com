{
  "name": "austinhumphrey-com",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pdf:export": "npx tsx scripts/export_resume.ts",
    "pdf:generate": "python3 scripts/generate_pdfs.py",
    "pdf:build": "npm run pdf:export && npm run pdf:generate",
    "image:generate": "bash scripts/generate_images.sh",
    "test:smoke": "npx playwright test",
    "cf:pages:create": "wrangler pages project create austin-humphrey-professional-resume-portfolio --production-branch main",
    "cf:pages:deploy": "npm run build && wrangler pages deploy dist --project-name austin-humphrey-professional-resume-portfolio",
    "cf:worker:deploy": "wrangler deploy",
    "cf:domain:attach": "wrangler pages project edit austin-humphrey-professional-resume-portfolio --domains austinhumphrey.com",
    "deploy:all": "npm run build && npm run pdf:build && npm run cf:pages:deploy && npm run cf:worker:deploy && npm run cf:domain:attach"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "framer-motion": "^12.34.0",
    "hono": "^4.11.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260213.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wrangler": "^4.65.0"
  }
}
